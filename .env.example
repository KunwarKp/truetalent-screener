# Flask settings
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# LLM provider configuration
# Insert your Grok (xAI) API key or OpenAI key
XAI_API_KEY=your_grok_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# External Verification Web Scraping Creds
# Optional APIs to prevent bot blocks on LinkedIn / Github portfolios
SCRAPING_API_KEY=your_scraping_bee_or_crawlbase_key_here
GITHUB_PAT=your_github_personal_access_token_here
